# GAON 배포용 env 템플릿 — 이 파일을 infra/`.env`로 복사해 값을 채운다(.env는 커밋 금지).
# 대상: 미니PC docker compose(배포). ⚠️ 로컬 개발용은 루트 ../.env.example (호스트명 localhost).
# ⚠️ 주의: compose의 env_file은 값을 "리터럴"로 컨테이너에 주입한다. ${...} 확장 안 됨.
#    그래서 DATABASE_URL·S3_* 는 아래처럼 실제 값을 직접 적어야 한다(POSTGRES_PASSWORD와 수기 일치).
# ⚠️ 컨테이너 내부 호스트명 사용: DB=postgres, 스토리지=minio (localhost 아님).

# ── tailnet 바인딩 ────────────────────────────────────────────────
# 미니PC의 tailnet IP. compose가 이 IP:포트로만 바인딩(공개 노출 방지).
TAILNET_IP=100.x.x.x

# ── PostgreSQL (postgres 서비스) ─────────────────────────────────
POSTGRES_USER=gaon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gaon

# ── MinIO (minio 서비스) ─────────────────────────────────────────
MINIO_ROOT_USER=gaon
MINIO_ROOT_PASSWORD=change-me

# ── 앱(be) 환경변수 ──────────────────────────────────────────────
APP_ENV=production
SESSION_SECRET=change-me

# DB: host는 서비스명 postgres. 값은 POSTGRES_* 와 일치시킬 것.
DATABASE_URL=postgresql://gaon:change-me@postgres:5432/gaon

# 객체 스토리지: endpoint=minio 서비스, 키는 MINIO_ROOT_* 와 일치.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=gaon
S3_SECRET_KEY=change-me
S3_BUCKET=gaon-documents

# Kakao OAuth
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=
KAKAO_CLIENT_SECRET=

# LLM / Embedding (결정 #4: API 셋업 시 확정. 비어 있어도 배포는 뜸 — AI 체인만 미동작)
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=

# FCM (push)
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=
