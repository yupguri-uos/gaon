# GAON 로컬 개발용 env 템플릿 — 루트 `.env`로 복사해 값을 채운다(.env는 커밋 금지).
# 대상: 호스트에서 직접 실행하는 `cd be && uvicorn app.main:app --reload` (DB·스토리지 = localhost).
# ⚠️ 배포(docker compose)용은 infra/.env.example — 호스트명이 postgres/minio라 서로 못 바꿔 쓴다.

APP_ENV=development
SESSION_SECRET=change-me

# DB (PostgreSQL + pgvector)
DATABASE_URL=postgresql://gaon:password@localhost:5432/gaon

# Kakao OAuth
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET

# 객체 스토리지 (MinIO / S3 호환)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=gaon-documents

# LLM (결정 #4: API 셋업 시 모델 확정)
LLM_API_KEY=
LLM_MODEL=

# Embedding (F-CORE-2 확정: KURE self-host, in-process, dim=1024)
EMBEDDING_MODEL=nlpai-lab/KURE-v1
# 빈 값이면 자동 선택(cuda → mps → cpu)
EMBEDDING_DEVICE=

# FCM (push)
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=